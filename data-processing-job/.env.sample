# Database
DATABASE_URL=postgresql+asyncpg://datahub:datahub@localhost:5435/datahub
PGSQL_SCHEMA=public

# Message broker
RABBITMQ_URL=amqp://guest:guest@localhost:5672/

# S3 / MinIO
S3_ENDPOINT_URL=http://localhost:9000
AWS_ACCESS_KEY_ID=minioadmin
AWS_SECRET_ACCESS_KEY=minioadmin
AWS_DEFAULT_REGION=ap-southeast-1
AWS_SESSION_TOKEN=
PREPROCESS_BUCKET_NAME=data-hub-preprocessing
UPSERT_BUCKET_NAME=data-hub-upsert

# External services
DOCUMENT_AI_URL=http://localhost:5000

# Chunking — markdown-aware parent-child splitter
# TIKTOKEN_MODEL_NAME=gpt-4o-mini
# RETRIEVE_MAX_TOKENS=2048      # gemini-embedding-001 cap
# RETRIEVE_TARGET_TOKENS=1800   # greedy pack target (margin under cap)

# Embedding API (LiteLLM)
EMBEDDING_API_BASE=http://localhost:4000/v1
EMBEDDING_MODEL_NAME=rag-embedding-model
EMBEDDING_API_KEY=fake
EMBEDDING_BATCH_SIZE=4

# Neo4j (for graph storage)
NEO4J_URI=bolt://localhost:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=datahub1!
NEO4J_DATABASE=neo4j

# GraphRAG — LLM for entity extraction
GRAPHRAG_LLM_API_BASE=http://localhost:4000/v1
GRAPHRAG_LLM_MODEL=graphrag-llm
GRAPHRAG_LLM_API_KEY=fake
GRAPHRAG_WORKING_DIR=/tmp/graphrag

# Postgres params for GraphRAG vector stores (mirrors DATABASE_URL host/port/creds)
POSTGRES_HOST=localhost
POSTGRES_PORT=5435
POSTGRES_USER=datahub
POSTGRES_PASSWORD=datahub
POSTGRES_DATABASE=datahub

# Server (health-check)
PORT=8001
