# Environment variables for docker-compose services

# Google Gemini API Key for LiteLLM embedding model
GEMINI_API_KEY=your-gemini-api-key-here

# Document AI service URL (optional, defaults to http://document-ai:5000)
DOCUMENT_AI_URL=http://document-ai:5000

# Pretrained model path for tokenizer (used in data-processing-job)
# Default: intfloat/multilingual-e5-large
PRETRAIN_MODEL_PATH=intfloat/multilingual-e5-large

# Embedding API settings (used in data-processing-job)
EMBEDDING_API_BASE=http://litellm:4000/v1
EMBEDDING_MODEL_NAME=rag-embedding-model
EMBEDDING_API_KEY=fake
EMBEDDING_BATCH_SIZE=4
